# ================================================
# PilTrace 환경변수 가이드
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요
# ================================================

# === Phase 1: 초기 론칭 (필수) ===

# OpenAI API Key
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Supabase Project URL
# 발급: https://supabase.com/dashboard → 프로젝트 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase Publishable Key (클라이언트용, 공개 가능)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase Service Role Key (서버용, 절대 공개 금지)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Supabase Pooler URL (포트 6543, 트랜잭션 모드)
# Supabase Dashboard → Settings → Database → Connection Pooling
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Direct URL (포트 5432, 마이그레이션용)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# App URL (로컬: http://localhost:3000, 프로덕션: https://yourdomain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Phase 2: MAU 1K+ (카카오 OAuth, 추후 도입) ===
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=

# === Phase 3: MAU 5K+ (Toss Payments, 추후 도입) ===
# TOSS_CLIENT_KEY=test_ck_...
# TOSS_SECRET_KEY=test_sk_...
